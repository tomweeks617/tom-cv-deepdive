# Copy to .env.local for local dev; set the same vars in Vercel for production.
ANTHROPIC_API_KEY=sk-ant-...
# Optional — defaults to claude-opus-4-8. Swap to claude-sonnet-4-6 / claude-haiku-4-5 to trial cheaper models.
ANTHROPIC_MODEL=claude-opus-4-8

# Optional — durable question logging via Axiom (axiom.co, free tier).
# Without these, events still go to stdout (Vercel Logs tab, ~1h retention).
AXIOM_TOKEN=xaat-...
AXIOM_DATASET=cv-chat
